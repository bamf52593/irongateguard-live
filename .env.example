# IronGate Environment Configuration
# Copy this file to .env and fill in your production values

# =============================
# DATABASE
# =============================
# Local development
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/irongate

# Production (uncomment and fill in)
# DATABASE_URL=postgresql://adminuser:securepassword@prod-db.amazonaws.com:5432/irongate_prod

# =============================
# JWT / AUTHENTICATION
# =============================
# IMPORTANT: Generate a strong random secret for production
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this-in-production

# Token expiration time (format: "7d" for 7 days, "24h" for 24 hours)
JWT_EXPIRY=7d

# =============================
# SERVER
# =============================
# Backend API port
API_PORT=404

# Frontend port (development only)
FRONTEND_PORT=3000

# Set NODE_ENV in your shell, container, or deployment platform if needed.
# Avoid putting NODE_ENV in Vite .env files because Vite warns on production values here.

# =============================
# FRONTEND
# =============================
# API endpoint for frontend (used in React)
VITE_API_URL=http://localhost:404/v1

# Production frontend URL
# VITE_API_URL=https://api.irongate.example.com/v1

# Stripe publishable key (frontend)
STRIPE_PUBLIC_KEY=pk_test_replace_me

# Stripe secret key (backend)
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe webhook signing secret (backend)
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# =============================
# BILLING USAGE OVERAGE PRICING
# =============================
# Extra device charge per day in cents (default: 50 = $0.50)
BILLING_EXTRA_DEVICE_DAILY_CENTS=50

# Extra user charge per day in cents (default: 10 = $0.10)
BILLING_EXTRA_USER_DAILY_CENTS=10

# Event overage billing block size (default: 10000 events)
BILLING_EVENT_BLOCK_SIZE=10000

# Charge per event block per billing month in cents (default: 500 = $5.00)
BILLING_EVENT_BLOCK_MONTHLY_CENTS=500

# =============================
# SECURITY
# =============================
# CORS allowed origins (comma-separated for production)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Session timeout in seconds (default: 7 days = 604800 seconds)
SESSION_TIMEOUT=604800

# =============================
# LOGGING
# =============================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log file location
LOG_FILE=logs/irongate.log

# =============================
# MONITORING & ANALYTICS (Optional)
# =============================
# Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/12345

# DataDog API key
# DATADOG_API_KEY=your-datadog-api-key

# =============================
# AWS DEPLOYMENT (if using AWS)
# =============================
# AWS Region
AWS_REGION=us-east-1

# RDS Database endpoint
# RDS_ENDPOINT=prod-db.xxxxxx.rds.amazonaws.com

# S3 bucket for logs (optional)
# AWS_S3_LOGS_BUCKET=irongate-logs-prod

# =============================
# SMTP / EMAIL (Optional)
# =============================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@irongate.example.com
