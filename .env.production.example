# Set NODE_ENV=production in the runtime environment or hosting platform.
# Keep it out of Vite .env files to avoid frontend build warnings.
API_PORT=4000
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRY=7d
DATABASE_URL=postgresql://username:password@your-db-host:5432/irongate
DB_SSL=true
FRONTEND_PORT=3000
VITE_API_URL=https://app.yourdomain.com/v1
CORS_ORIGIN=https://app.yourdomain.com
SESSION_TIMEOUT=604800
LOG_LEVEL=info

STRIPE_PUBLIC_KEY=pk_live_replace_me
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
FRONTEND_URL=https://app.yourdomain.com
VITE_BILLING_PAYWALL_BYPASS=false

SENDGRID_API_KEY=SG.replace_me
FROM_EMAIL=noreply@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com
SALES_EMAIL=sales@yourdomain.com

BILLING_API_BASE=https://app.yourdomain.com/v1
BILLING_ADMIN_EMAIL=admin@yourdomain.com
BILLING_ADMIN_PASSWORD=replace_me
LIVE_BILLING_REQUIRE_LIVE_KEYS=true
